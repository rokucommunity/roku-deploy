{
    "name": "roku-deploy",
    "version": "4.0.0-alpha.2",
    "description": "Package and publish a Roku application using Node.js",
    "main": "dist/index.js",
    "scripts": {
        "build": "npm run clean && tsc",
        "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
        "preversion": "npm run build && npm run lint && npm run test",
        "prepublishOnly": "npm run build",
        "watch": "npm run clean && tsc --watch",
        "lint": "eslint \"./src/**/*.ts\"",
        "audit": "npm audit || audit-ci --config ./audit-ci.jsonc",
        "test": "nyc mocha \"src/**/*.spec.ts\" --exclude \"src/device.spec.ts\"",
        "test:nocover": "mocha \"src/**/*.spec.ts\" --exclude \"src/device.spec.ts\"",
        "test:device": "mocha src/device.spec.ts",
        "test:all": "nyc mocha \"src/**/*.spec.ts\"",
        "test-without-sourcemaps": "npm run build && nyc mocha dist/**/*.spec.js",
        "package": "npm run build && npm pack"
    },
    "dependencies": {
        "@rokucommunity/logger": "^0.4.1",
        "chalk": "^2.4.2",
        "fast-glob": "^3.2.12",
        "fs-extra": "^7.0.1",
        "is-glob": "^4.0.3",
        "jsonc-parser": "^2.3.0",
        "jszip": "^3.10.1",
        "micromatch": "^4.0.4",
        "needle": "^3.5.0",
        "picomatch": "^2.3.2",
        "semver": "^7.7.3",
        "ws": "^8.21.1",
        "xml2js": "^0.5.0",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@types/chai": "^4.2.22",
        "@types/fs-extra": "^5.0.1",
        "@types/is-glob": "^4.0.2",
        "@types/micromatch": "^4.0.2",
        "@types/mocha": "^10.0.0",
        "@types/needle": "^3.3.0",
        "@types/node": "^18.19.0",
        "@types/picomatch": "^2.3.4",
        "@types/semver": "^7.7.1",
        "@types/sinon": "^10.0.4",
        "@types/ws": "^8.18.1",
        "@types/xml2js": "^0.4.5",
        "@types/yargs": "^17.0.32",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.59.11",
        "audit-ci": "^7.1.0",
        "chai": "^4.3.4",
        "dotenv": "^17.4.2",
        "eslint": "^8.56.0",
        "eslint-plugin-import": "^2.29.1",
        "mocha": "^10.8.2",
        "nyc": "^17.1.0",
        "q": "^1.5.1",
        "rimraf": "^6.0.1",
        "sinon": "^12.0.0",
        "source-map-support": "^0.5.21",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.3",
        "typescript-eslint": "^7.4.0",
        "undent": "^1.0.0"
    },
    "overrides": {
        "serialize-javascript": "^7.0.5",
        "istanbul-lib-processinfo": {
            "uuid": "^11.1.1"
        }
    },
    "mocha": {
        "require": [
            "source-map-support/register",
            "ts-node/register"
        ],
        "fullTrace": true,
        "watchExtensions": [
            "ts"
        ]
    },
    "typings": "dist/index.d.ts",
    "bin": {
        "roku-deploy": "dist/cli.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/rokucommunity/roku-deploy"
    },
    "author": "RokuCommunity",
    "license": "MIT",
    "nyc": {
        "include": [
            "src/**/*.ts",
            "!src/Errors.ts",
            "!src/**/*.spec.ts"
        ],
        "extension": [
            ".ts"
        ],
        "require": [
            "ts-node/register",
            "source-map-support/register"
        ],
        "reporter": [
            "text-summary",
            "html",
            "lcovonly"
        ],
        "sourceMap": true,
        "instrument": true,
        "check-coverage": false,
        "lines": 100,
        "statements": 100,
        "functions": 100,
        "branches": 100
    }
}
